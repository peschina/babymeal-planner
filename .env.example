# Environment Variables — BabyMeal Planner
# Copy this file to .env and fill in values for local development.

# ─── Backend ───────────────────────────────────────────────────────────────────
# Port the Fastify server listens on
API_PORT=4001

# ─── Frontend ──────────────────────────────────────────────────────────────────
# Port the SvelteKit Node server listens on
FRONTEND_PORT=3000

# Backend URL used by the SvelteKit Node server (SSR + proxy route).
# Server-only — NOT prefixed with PUBLIC_ and MUST NOT be read by browser code.
# In Docker Compose this resolves to the internal service name.
API_URL=http://localhost:4001

# API base path for client-side fetch (proxied through SvelteKit).
# Safe to expose — contains no hostnames.
PUBLIC_API_BASE=/api

# ─── Shared ────────────────────────────────────────────────────────────────────
NODE_ENV=development
