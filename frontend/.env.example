# Frontend environment variables
# Copy this file to .env and fill in your values

# Port the SvelteKit dev server listens on
FRONTEND_PORT=3000

# Backend URL used by the SvelteKit Node server only (SSR + proxy route).
# Never exposed to browser code — do NOT add a PUBLIC_ prefix here.
# In Docker, this points to the backend service: http://backend:3001
API_URL=http://localhost:4001

# API base path for client-side fetch calls (proxied through SvelteKit).
# Safe to expose to the browser — contains no hostnames.
PUBLIC_API_BASE=/api

# Runtime environment
NODE_ENV=development
